{
  "manifest_version": 3,
  "name": "Poetrystack",
  "version": "1.0.0",
  "description": "Allows you to restack poetry-formatted text on Substack - just select any poetry block and restack it.",
  "permissions": ["clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "minimum_chrome_version": "100",
  "background": {
    "service_worker": "background.js"
  },
"content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "icons": {
    "16": "icons/logo16.png",
    "48": "icons/logo48.png",
    "128": "icons/logo128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo16.png",
      "32": "icons/logo32.png",
      "48": "icons/logo48.png"
    },
    "default_title": "Poetrystack"
  }
}